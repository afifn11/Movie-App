# TMDB API (v4 Read Access Token) — https://www.themoviedb.org/settings/api
VITE_TMDB_READ_TOKEN=your_tmdb_v4_read_access_token_here

# Supabase — https://supabase.com → Project Settings → API
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# Google Gemini — AMAN DI SERVERLESS (Hapus VITE_ prefix agar tidak bocor ke browser)
GEMINI_API_KEY=your_gemini_api_key_here

# Sentry — https://sentry.io
VITE_SENTRY_DSN=https://your_sentry_dsn_here